# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dpms_v2

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email Adapter (Gmail SMTP) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ─── SMS Adapter (Twilio — future) ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── ABHA / UHID (dummy for local) ──────────────────────
ABHA_API_URL=http://localhost:8001/api/abha
ABHA_API_KEY=dummy-key-local

# ─── OpenAI ──────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── MongoDB (conversation history) ─────────────────────
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=dpms_v2_chat

# ─── ChromaDB (RAG) ─────────────────────────────────────
CHROMA_PERSIST_DIRECTORY=./chroma_data

# ─── App ─────────────────────────────────────────────────
APP_NAME=DPMS_v2
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
